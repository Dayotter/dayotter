# ---- Core ----
NODE_ENV=development
APP_URL=http://localhost:3000
# Canonical public site origin, baked into the web build (drives marketing
# metadata, sitemap, canonical URLs, JSON-LD). Defaults to APP_URL's value here /
# https://dayotter.com in prod. Set to your real domain for correct SEO tags.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Log verbosity: debug | info | warn | error. Defaults to "info".
LOG_LEVEL=info

# ---- Extensions / plugins (optional) ----
# Comma-separated ids of the plugins to enable. OFF by default - nothing changes
# unless set. First-party examples: notes, webhook-relay. Plugins run in-process
# with full access, so only enable ones you trust. Per-plugin config is passed as
# DAYOTTER_PLUGIN_<ID>_<KEY> (e.g. DAYOTTER_PLUGIN_WEBHOOK_RELAY_URL=https://…).
# See docs/BUILDING_EXTENSIONS or /docs/building-extensions.
DAYOTTER_PLUGINS=

# 32+ char random string (openssl rand -base64 32) - REQUIRED, no default in prod
AUTH_SECRET=

# Better Auth (defaults to AUTH_SECRET / APP_URL if unset)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ---- Database (Postgres) ----
DATABASE_URL=postgresql://dayotter:dayotter@localhost:5432/dayotter
# Host port the Postgres container binds to. Change this if 5432 is already
# taken by another Postgres, and update the port in DATABASE_URL to match.
POSTGRES_PORT=5432

# ---- Redis (queues / cache) ----
REDIS_URL=redis://localhost:6379
# Host port the Redis container binds to (change if 6379 is taken).
REDIS_PORT=6379

# ---- Encryption for stored OAuth tokens ----
# 32-byte key, hex-encoded - REQUIRED. Generate with: openssl rand -hex 32
# (The all-zero placeholder is rejected at runtime - you must set a real key.)
ENCRYPTION_KEY=

# ---- Google Calendar OAuth (also powers "Sign in with Google") ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to 1 to show the "Sign in with Google" button (needs the creds above +
# ${APP_URL}/api/auth/callback/google registered as an authorized redirect URI).
NEXT_PUBLIC_GOOGLE_AUTH=

# ---- Microsoft / Outlook OAuth ----
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ---- Zoom integration (optional) ----
# Auto-creates a Zoom meeting for "zoom" event types when a host connects Zoom.
# Hidden entirely when unset. Register a Zoom OAuth app with redirect
# ${APP_URL}/api/integrations/zoom/callback and scope meeting:write.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ---- CRM sync (optional, Salesforce / HubSpot) ----
# Native sync: every booking logs a contact + meeting to your CRM. A provider is
# inert (hidden in settings) until BOTH its id and secret are set. Register an
# OAuth app with the callback ${APP_URL}/api/integrations/crm/<provider>/callback.
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ---- Email ----
# Preferred: Resend HTTP API - set your key and a FROM on a domain you've
# verified in Resend. This is all you need (no SMTP_URL required).
RESEND_API_KEY=
# Alternative: any SMTP server, e.g. smtp://user:pass@smtp.example.com:587
# (Resend also works over SMTP: smtps://resend:re_yourkey@smtp.resend.com:465)
SMTP_URL=
# The From address. It MUST be on a domain you've verified with your provider -
# an unverified/placeholder domain (e.g. example.com) makes EVERY email bounce
# with a 550. Change this to your own verified domain before going live.
EMAIL_FROM="DayOtter <no-reply@dayotter.com>"
# Where the public contact form sends messages. Defaults to hello@dayotter.com.
CONTACT_EMAIL=

# ---- Captcha on the public booking form (optional) ----
# Cloudflare Turnstile. Leave blank to disable captcha entirely.
TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---- Analytics (optional) ----
# Nothing loads unless set - each provider is independent, mix and match freely.
# End users can additionally opt out per-browser in Settings -> Preferences.
# Mixpanel project token + GA4 measurement id + PostHog project key/host.
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- AI scheduling (optional) ----
# Anthropic API key. AI quick-add is hidden unless set. Confirm-first, scheduling-only.
ANTHROPIC_API_KEY=

# ---- Reminder channels (optional) ----
# Slack and mobile push need no server creds - the destination is stored per-user.
# WhatsApp + SMS reminders use Twilio; leave blank to hide those channel types.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=        # e.g. whatsapp:+14155238886
TWILIO_SMS_FROM=             # e.g. +14155238886 (also used for phone sign-in codes)

# ---- Talk to Otter over SMS/WhatsApp + AI voice receptionist (optional) ----
# Inbound messaging/voice via Twilio. Point your Twilio number's webhooks at
# ${APP_URL}/api/webhooks/twilio (messaging) and .../voice (voice).
# The number people text to reach Otter (shown in settings). Falls back to
# TWILIO_SMS_FROM when unset.
OTTER_SMS_NUMBER=
# Override the public base URL used to validate Twilio's request signature - only
# needed if it differs from APP_URL (e.g. behind a proxy/tunnel). Defaults to APP_URL.
TWILIO_WEBHOOK_URL=
# The single host (their booking-page handle) the AI voice receptionist answers
# for. Leave blank to disable the voice receptionist.
VOICE_RECEPTIONIST_HANDLE=

# ---- Phone + OTP sign-in (optional) ----
# The server enables phone sign-in automatically when Twilio is configured above
# (it sends the SMS code). Set the flag below to 1 to show the "Continue with
# phone" button on the web sign-in page. The mobile app uses EXPO_PUBLIC_PHONE_AUTH.
NEXT_PUBLIC_PHONE_AUTH=

# ---- Browser (Web Push) notifications (optional) ----
# Desktop/browser meeting reminders. Generate a keypair once:
#   npx web-push generate-vapid-keys
# Set both keys, and expose the public one to the browser (must match VAPID_PUBLIC_KEY).
# VAPID_SUBJECT is a contact mailto: or https URL. Unset = the channel is hidden.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@dayotter.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ---- Payments (optional, Stripe) ----
# Paid event types are hidden unless STRIPE_SECRET_KEY is set. The webhook secret
# comes from `stripe listen` (dev) or the Dashboard endpoint (prod).
STRIPE_SECRET_KEY=
# Stripe Connect (hosts get paid directly for bookings/packages via Express
# accounts). Enable Connect in your Stripe Dashboard. Optional platform cut per
# host transaction as a percentage (0 = none). Also subscribe your webhook to
# `account.updated`.
STRIPE_PLATFORM_FEE_PERCENT=0
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Editions / billing (see docs/EDITIONS.md) ----
# LEAVE DAYOTTER_CLOUD UNSET to self-host: every feature is free, no billing.
# Set DAYOTTER_CLOUD=1 only for the hosted product (free tier + $9/seat Pro plan).
DAYOTTER_CLOUD=
# The recurring Stripe Price for the $9/seat Pro plan (cloud only).
# MUST be a Price object ID (starts with "price_"), NOT a number/amount. Create a
# Product with a recurring price in the Stripe Dashboard and copy its price_... id.
STRIPE_PRICE_PRO=
# Cloud-only (ee/) managed credentials - ignored when self-hosting.
DAYOTTER_MANAGED_ANTHROPIC_KEY=
DAYOTTER_MANAGED_TWILIO_SID=
DAYOTTER_MANAGED_TWILIO_TOKEN=
DAYOTTER_MANAGED_TWILIO_SMS_FROM=
DAYOTTER_MANAGED_TWILIO_WA_FROM=
