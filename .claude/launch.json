{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@dayotter/web", "dev"],
      "port": 3000
    },
    {
      "name": "web-cloud",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@dayotter/web", "dev"],
      "port": 3000,
      "env": { "DAYOTTER_CLOUD": "1" }
    }
  ]
}
