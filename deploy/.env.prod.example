# dayotter self-host environment.
#
# `bash deploy/install.sh` generates a filled-in copy of this as deploy/.env with
# strong random secrets. Copy it by hand only if you're not using the installer:
#   cp deploy/.env.prod.example deploy/.env  &&  edit the REQUIRED values.
#
# After changing anything here: `cd deploy && docker compose -f docker-compose.prod.yml up -d`

# ---- REQUIRED ----------------------------------------------------------------

# Public URL people reach your dayotter at. With a domain use https://; for a
# quick IP trial use http://YOUR_SERVER_IP. Must match DAYOTTER_SITE_ADDRESS.
APP_URL=https://cal.example.com
BETTER_AUTH_URL=https://cal.example.com

# Caddy front-door address: your domain for automatic HTTPS, or ":80" for HTTP.
DAYOTTER_SITE_ADDRESS=cal.example.com

# Postgres password for the bundled database (any long random string).
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# 32+ char random string.        Generate: openssl rand -base64 32
AUTH_SECRET=
BETTER_AUTH_SECRET=

# 32-byte hex key for encrypting stored OAuth tokens at rest.
# Generate: openssl rand -hex 32   (the all-zero placeholder is rejected)
ENCRYPTION_KEY=

NODE_ENV=production

# ---- OPTIONAL (leave blank to disable the feature) ---------------------------

# Google Calendar + "Sign in with Google". Redirect URI to register:
#   ${APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_AUTH=

# Microsoft / Outlook calendar.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Outbound email (booking confirmations, reminders, password resets).
# Without it, those emails are logged to the container instead of sent.
SMTP_URL=
EMAIL_FROM="dayotter <no-reply@example.com>"

# AI scheduling (Anthropic). Hidden entirely when unset.
ANTHROPIC_API_KEY=

# Zoom auto-meeting for "zoom" event types.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Payments (Stripe). Paid event types are hidden unless set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# SMS / WhatsApp reminders (Twilio).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# Captcha on the public booking form (Cloudflare Turnstile).
TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# NOTE: values prefixed NEXT_PUBLIC_ are baked into the web build. Changing them
# needs a rebuild:  cd deploy && docker compose -f docker-compose.prod.yml up -d --build
