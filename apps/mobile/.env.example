# DayOtter mobile (Expo) environment.
#
# Expo inlines EXPO_PUBLIC_* vars into the JS bundle at build time. For local dev,
# copy this to apps/mobile/.env (or prefix them on the start command). Build-time
# values for release builds live in eas.json.
#
# All are optional - the app has sensible defaults.

# The DayOtter API/server the app talks to. Defaults to https://dayotter.com.
# For local dev against a server on your machine:
#   EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=

# Show "Continue with Google" on the sign-in screen (1 = on). Needs Google OAuth
# configured on the server. Defaults off.
EXPO_PUBLIC_GOOGLE_AUTH=

# Show "Continue with phone" (SMS code) on the sign-in screen (1 = on). Needs
# Twilio configured on the server. Defaults off.
EXPO_PUBLIC_PHONE_AUTH=
